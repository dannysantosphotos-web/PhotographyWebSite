<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <rect width="100" height="100" fill="white"/>

  <!-- Shutter blades forming a D shape -->
  <g fill="black">
    <path d="M30 15 L70 25 L55 40 L25 30 Z"/>
    <path d="M70 25 L85 50 L60 50 L55 40 Z"/>
    <path d="M85 50 L70 75 L55 60 L60 50 Z"/>
    <path d="M70 75 L30 85 L40 60 L55 60 Z"/>
    <path d="M30 85 L20 50 L40 60 Z"/>
    <path d="M20 50 L30 15 L40 40 Z"/>
  </g>

  <!-- Inner lens circle -->
  <circle cx="50" cy="50" r="10" fill="white"/>
</svg>